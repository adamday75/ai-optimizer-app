{
  "name": "ai-optimizer",
  "version": "2.1.1",
  "description": "AI Optimizer v2 - Proxy server with caching to save 20-40% on OpenAI API costs",
  "main": "src/main.js",
  "homepage": "https://ai-optimizer-landing.vercel.app",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "author": {
    "name": "Gary & Adam",
    "email": "garyday216@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "express": "^5.2.1",
    "node-cache": "^5.1.2",
    "openai": "^6.32.0"
  },
  "build": {
    "appId": "com.ai-optimizer.app",
    "productName": "AI Optimizer",
    "publish": null,
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
